{
  "name": "@kurone-kito/kit.black-root",
  "version": "1.0.0",
  "private": true,
  "description": "Website of kurone-kito",
  "keywords": ["VTuber", "website"],
  "homepage": "https://github.com/kurone-kito/kit.black#readme",
  "bugs": "https://github.com/kurone-kito/kit.black/issues",
  "repository": "github:kurone-kito/kit.black",
  "license": "CC-BY-NC-4.0",
  "author": "kurone-kito <krone@kit.black> (https://kit.black/)",
  "type": "module",
  "files": [],
  "workspaces": {
    "packages": ["./packages/*"]
  },
  "scripts": {
    "build": "pnpm --aggregate-output -r run build",
    "build:min": "pnpm --filter \"@kurone-kito/kit.black-lib\" run build",
    "clean": "pnpm run --no-bail \"/^clean:.+/\"",
    "clean:root": "rimraf -g \"*.tgz\" \"*.tsbuildinfo\" \"node_modules/.cache/**/*\"",
    "clean:sub": "pnpm --parallel -r run clean",
    "dev": "pnpm run --parallel -r dev",
    "lint": "pnpm run \"/lint:.+:check/\"",
    "lint:biome:check": "biome check",
    "lint:biome:fix": "biome check --write",
    "lint:cspell:check": "cspell lint --no-progress --show-suggestions -u \"./**/*\"",
    "lint:fix": "pnpm run \"/lint:.+:fix/\"",
    "lint:markdown:check": "markdownlint-cli2 \"**/*.md\"",
    "lint:markdown:fix": "markdownlint-cli2 --fix \"**/*.md\"",
    "pnpm:devPreinstall": "pnpm run -r devPreinstall",
    "postlint:fix": "pnpm run lint:cspell:check",
    "prebuild": "nodetouch .env",
    "predev": "pnpm run build:min",
    "prepare": "husky",
    "pretest": "pnpm run build:min",
    "test": "pnpm run \"/test:.+/\"",
    "test:e2e": "pnpm run -r test:e2e",
    "test:ts": "pnpm --aggregate-output -r exec tsc -p tsconfig.test.json --noEmit",
    "test:vitest": "NODE_OPTIONS=\"--conditions=browser\" vitest run --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@cspell/cspell-types": "^9.2.0",
    "@kurone-kito/biome-config": "0.20.0",
    "@kurone-kito/commitlint-config": "^0.20.0",
    "@kurone-kito/cspell-config": "^0.20.0",
    "@kurone-kito/lint-staged-config": "^0.20.0",
    "@kurone-kito/markdownlint-config": "^0.20.0",
    "@kurone-kito/typescript-config": "^0.20.0",
    "@vitest/coverage-v8": "^3.2.4",
    "cspell": "^9.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "markdownlint-cli2": "^0.18.1",
    "rimraf": "^6.0.1",
    "touch": "^3.1.1",
    "typescript": "~5.9.2",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.14.0+sha512.ad27a79641b49c3e481a16a805baa71817a04bbe06a38d17e60e2eaee83f6a146c6a688125f5792e48dd5ba30e7da52a5cda4c3992b9ccf333f9ce223af84748",
  "engines": {
    "node": "^22 || >=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
