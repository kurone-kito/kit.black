{
  "name": "@kurone-kito/kit.black-fetcher",
  "version": "1.0.0",
  "private": true,
  "description": "the API fetcher for kit.black",
  "homepage": "https://github.com/kurone-kito/kit.black#readme",
  "bugs": "https://github.com/kurone-kito/kit.black/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/kurone-kito/kit.black.git",
    "directory": "packages/fetcher"
  },
  "license": "MIT",
  "author": "kurone-kito <krone@kit.black> (https://kit.black/)",
  "type": "module",
  "exports": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "kb-fetcher": "./dist/bin.mjs"
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "clean": "rimraf -g \"*.tgz\" \"*.tsbuildinfo\" coverage dist node_modules/.cache",
    "dev": "vite build --watch",
    "devPreinstall": "pnpm dlx mkdirp dist && pnpm dlx shx head -n 1 src/bin.mts > dist/bin.mjs",
    "kb-fetcher": "node dist/bin.mjs",
    "prepack": "pnpm run clean && pnpm run build",
    "test": "pnpm run \"/test:.+/\"",
    "test:ts": "tsc -p tsconfig.test.json --noEmit",
    "test:vitest": "vitest run --coverage"
  },
  "dependencies": {
    "@kurone-kito/kit.black-lib": "workspace:^",
    "googleapis": "^150.0.1"
  },
  "devDependencies": {
    "@kurone-kito/typescript-config": "^0.20.0",
    "@kurone-kito/vite-lib-config": "^0.20.0",
    "@types/node": "^24.0.10",
    "@vitest/coverage-v8": "^3.2.4",
    "google-auth-library": "^10.1.0",
    "rimraf": "^6.0.1",
    "type-fest": "^4.41.0",
    "typescript": "~5.9.2",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": "^22 || >=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
