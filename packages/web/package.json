{
  "name": "@kurone-kito/kit.black-web",
  "version": "1.0.0",
  "private": true,
  "description": "the API fetcher for kit.black",
  "homepage": "https://github.com/kurone-kito/kit.black#readme",
  "bugs": "https://github.com/kurone-kito/kit.black/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/kurone-kito/kit.black.git",
    "directory": "packages/web"
  },
  "license": "CC-BY-NC-4.0",
  "author": "kurone-kito <krone@kit.black> (https://kit.black/)",
  "type": "module",
  "files": [".output", ".vinxi"],
  "scripts": {
    "build": "vinxi build",
    "build:storybook": "storybook build",
    "clean": "rimraf -g \"*.tgz\" \"*.tsbuildinfo\" .output .vinxi dist node_modules/.cache \"src/*.json\" storybook-static",
    "dev": "vinxi dev",
    "dev:storybook": "storybook dev -p 6006",
    "prebuild": "pnpm run \"/^prebuild:.+/\"",
    "prebuild:fetcher": "kb-fetcher > src/data.json",
    "prebuild:yaml": "js-yaml src/constants.yaml > src/constants.json",
    "predev": "pnpm run prebuild",
    "serve": "serve dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@kurone-kito/kit.black-lib": "workspace:^",
    "@kurone-kito/launchpad-icons-solid": "0.14.0",
    "@solid-primitives/date": "^2.1.0",
    "@solid-primitives/i18n": "^2.2.0",
    "@solid-primitives/media": "^2.3.0",
    "@solid-primitives/storage": "^4.3.1",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.3",
    "@solidjs/start": "^1.1.5",
    "solid-icons": "^1.1.0",
    "solid-js": "^1.9.7",
    "tailwind-merge": "^3.3.1",
    "theme-change": "^2.5.0"
  },
  "devDependencies": {
    "@kurone-kito/kit.black-fetcher": "workspace:^",
    "@kurone-kito/typescript-config": "^0.20.0",
    "@kurone-kito/vrc-icons-tw": "^0.14.0",
    "@playwright/test": "^1.53.2",
    "@solidjs/testing-library": "^0.8.10",
    "@storybook/addon-essentials": "^8.5.3",
    "@storybook/addon-interactions": "^8.5.3",
    "@storybook/addon-links": "^8.5.3",
    "@storybook/blocks": "^8.5.3",
    "@storybook/builder-vite": "^8.5.3",
    "@storybook/docs-tools": "^8.5.3",
    "@storybook/types": "^8.5.3",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/vite": "^4.1.11",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-link-attributes": "^3.0.5",
    "@types/node": "^24.0.7",
    "@vitest/coverage-v8": "^3.2.4",
    "daisyui": "^5.0.43",
    "js-yaml": "^4.1.0",
    "jsdom": "^26.1.0",
    "markdown-it": "^14.1.0",
    "markdown-it-link-attributes": "^4.0.1",
    "rimraf": "^6.0.1",
    "serve": "^14.2.4",
    "storybook": "^8.5.3",
    "storybook-solidjs": "1.0.0-beta.6",
    "storybook-solidjs-vite": "1.0.0-beta.6",
    "tailwindcss": "^4.1.11",
    "tailwindcss-safe-area": "^0.6.0",
    "type-fest": "^4.41.0",
    "typescript": "~5.9.2",
    "vinxi": "^0.5.7",
    "vite": "^6.0.11",
    "vite-plugin-markdown": "^2.2.0",
    "vite-plugin-solid": "^2.11.7",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": "^22 || >=24"
  },
  "publishConfig": {
    "access": "public"
  }
